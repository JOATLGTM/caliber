{
  "manifest_version": 3,
  "name": "Caliber Apply Autofill",
  "version": "1.0.9",
  "description": "Prefill Greenhouse, Lever, and Ashby job applications from your Caliber profile.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://localhost:3000/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Caliber Autofill"
  }
}
